{
  "uid": "value-sum-per-type",
  "title": "Total Value Sum per Task Type",
  "tags": ["task-pipeline"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Sum of Value per Type",
      "type": "bargauge",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "consumer_value_sum_per_type_total",
          "legendFormat": "type {{type}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Value Sum per Type Over Time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(consumer_value_sum_per_type_total[1m])",
          "legendFormat": "type {{type}}"
        }
      ]
    }
  ]
}
