{
  "uid": "messages-per-state",
  "title": "Messages per State",
  "tags": ["task-pipeline"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Tasks by State (Current)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "tasks_by_state",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Tasks by State Over Time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "tasks_by_state{state=\"received\"}",
          "legendFormat": "received"
        },
        {
          "expr": "tasks_by_state{state=\"processing\"}",
          "legendFormat": "processing"
        },
        {
          "expr": "tasks_by_state{state=\"done\"}",
          "legendFormat": "done"
        }
      ]
    }
  ]
}
