FROM golang:1.26-alpine AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG VERSION=dev
RUN CGO_ENABLED=0 go build -ldflags="-s -w -X main.version=${VERSION}" -o /bin/consumer ./cmd/consumer

FROM alpine:3.21

RUN apk --no-cache add ca-certificates
COPY --from=builder /bin/consumer /usr/local/bin/consumer

ENTRYPOINT ["consumer"]
